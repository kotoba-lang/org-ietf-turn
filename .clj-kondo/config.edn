{;; nbb bundles promesa.core (see test/kotoba/turn/listener_demo.cljs) but
 ;; this repo does not declare it as an mvn dependency, so clj-kondo can't
 ;; analyze its macros from source. p/let expands like clojure.core/let
 ;; (sequential bindings, body) — tell clj-kondo so it doesn't flag every
 ;; binding introduced inside it as an unresolved symbol. Same fix
 ;; kotoba-lang/dtn's .clj-kondo/config.edn already applies for the same
 ;; reason (that repo's test/kotoba/dtn/transport/tcp_demo.cljs uses the
 ;; identical pattern).
 :lint-as {promesa.core/let clojure.core/let
           promesa.core/do! clojure.core/do}}
